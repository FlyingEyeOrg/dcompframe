{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "vs2022-base",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_CXX_EXTENSIONS": "OFF"
            }
        },
        {
            "name": "vs2022-x64",
            "displayName": "VS2022 x64",
            "description": "Configure with the Visual Studio 2022 generator for 64-bit builds.",
            "inherits": "vs2022-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows-static"
            },
            "architecture": {
                "value": "x64",
                "strategy": "set"
            }
        },
        {
            "name": "vs2022-x86",
            "displayName": "VS2022 x86",
            "description": "Configure with the Visual Studio 2022 generator for 32-bit builds.",
            "inherits": "vs2022-base",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x86-windows-static"
            },
            "architecture": {
                "value": "Win32",
                "strategy": "set"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "vs2022-x64-debug",
            "displayName": "Build x64 Debug",
            "configurePreset": "vs2022-x64",
            "configuration": "Debug"
        },
        {
            "name": "vs2022-x64-release",
            "displayName": "Build x64 Release",
            "configurePreset": "vs2022-x64",
            "configuration": "Release"
        },
        {
            "name": "vs2022-x86-debug",
            "displayName": "Build x86 Debug",
            "configurePreset": "vs2022-x86",
            "configuration": "Debug"
        },
        {
            "name": "vs2022-x86-release",
            "displayName": "Build x86 Release",
            "configurePreset": "vs2022-x86",
            "configuration": "Release"
        }
    ],
    "testPresets": [
        {
            "name": "vs2022-x64-debug-tests",
            "configurePreset": "vs2022-x64",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "vs2022-x86-debug-tests",
            "configurePreset": "vs2022-x86",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}